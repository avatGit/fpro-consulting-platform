{
  "name": "f-pro_consulting",
  "version": "1.0.0",
  "description": "Backend API for F-PRO CONSULTING - Digital Services Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:sync": "node -e \"require('./src/models').syncModels({force: true})\"",
    "db:sync:alter": "node -e \"require('./src/models').syncModels({alter: true})\"",
    "db:seed": "node -e \"require('./src/seedData')()\"",
    "db:seed:demo": "node seed_demo_users.js",
    "logs:clear": "rm -rf logs/*.log || del /Q logs\\*.log"
  },
  "keywords": [
    "api",
    "backend",
    "consulting",
    "b2b"
  ],
  "author": "F-PRO CONSULTING Team",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.3.1",
    "helmet": "^8.0.0",
    "joi": "^18.0.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pdfmake": "^0.3.3",
    "pg": "^8.13.1",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.2"
  }
}