# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fpro_consulting
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d


# CORS Configuration
CORS_ORIGIN=*

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
# Si vous utilisez votre compte gmail, vous devez activer le 2FA et générer un mot de passe d'application
SMTP_PASS=your_app_password
SMTP_FROM=F-PRO CONSULTING <noreply@fpro-consulting.com>

# SMS Configuration (Mock by default, configure for Twilio)
SMS_PROVIDER=mock
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=+1234567890

# Redis Configuration (Optional - uses in-memory cache if not provided)
REDIS_URL=

# Logging Configuration
LOG_LEVEL=debug