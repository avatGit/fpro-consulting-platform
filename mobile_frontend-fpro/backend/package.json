{
  "name": "f-pro_consulting",
  "version": "1.0.0",
  "description": "Backend API for F-PRO CONSULTING - Digital Services Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:sync": "node -e \"require('./src/config/database').syncDatabase({force: true})\"",
    "db:sync:alter": "node -e \"require('./src/config/database').syncDatabase({alter: true})\"",
    "db:seed": "node -e \"require('./src/seedData')()\"",
    "logs:clear": "rm -rf logs/*.log || del /Q logs\\*.log"
  },
  "keywords": [
    "api",
    "backend",
    "consulting",
    "b2b"
  ],
  "author": "F-PRO CONSULTING Team",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.1",
    "helmet": "^8.0.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "pdfmake": "^0.3.3",
    "pg": "^8.13.1",
    "roboto-fontface": "^0.10.0",
    "sequelize": "^6.37.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.11.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.2"
  }
}
